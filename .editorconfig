root = true

[*]
charset = utf-8
end_of_line = lf
trim_trailing_whitespace = true
insert_final_newline = true

# Python — PEP 8, matches ruff config (line-length = 100)
[*.py]
indent_style = space
indent_size = 4
max_line_length = 100

# TypeScript / JavaScript / JSON / config files — JS ecosystem standard
[*.{ts,tsx,js,jsx,mjs,cjs,json,jsonc}]
indent_style = space
indent_size = 2

# Markup & config
[*.{yaml,yml,toml,css,html,md,mdx}]
indent_style = space
indent_size = 2

# Makefiles require real tabs
[Makefile]
indent_style = tab
