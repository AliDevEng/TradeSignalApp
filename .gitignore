# =============================================================================
# TradeSignal AI — Monorepo .gitignore
# Covers: Python / FastAPI backend  +  Next.js / TypeScript frontend
# =============================================================================

# -----------------------------------------------------------------------------
# Environment & secrets — NEVER commit
# -----------------------------------------------------------------------------
.env
.env.*
!.env.example
!.env.*.example

# -----------------------------------------------------------------------------
# Python / Backend
# -----------------------------------------------------------------------------
.venv/
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg
*.egg-info/
.eggs/
dist/
build/
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
.coverage.*
coverage.xml
htmlcov/
*.db
*.sqlite3

# -----------------------------------------------------------------------------
# Node.js / Frontend
# -----------------------------------------------------------------------------
node_modules/
.next/
out/
*.tsbuildinfo
.next-dev*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
pnpm-debug.log*

# -----------------------------------------------------------------------------
# OS
# -----------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
Thumbs.db
Desktop.ini

# -----------------------------------------------------------------------------
# IDE & editors
# -----------------------------------------------------------------------------
.idea/
.vscode/
*.swp
*.swo
*~
