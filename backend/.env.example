# Copy this file to .env and fill in the values before running the server.

# App
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=true

# Comma-separated allowed CORS origins. Empty disables CORS entirely.
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Database
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/tradesignal

# Connection pool — tune for higher concurrency. Leave defaults for a single
# backend instance against a same-network Postgres.
# DATABASE_POOL_SIZE=10
# DATABASE_MAX_OVERFLOW=20
# DATABASE_POOL_RECYCLE_SECONDS=1800
# DATABASE_ECHO=false

# AI Provider — switch to "anthropic" + claude-sonnet-4-6 for production
AI_PROVIDER=groq
AI_MODEL=llama-3.3-70b-versatile
AI_API_KEY=your_groq_api_key_here
# Recent candles per timeframe in each prompt — the main prompt-size lever.
# Keep low on Groq's free tier (12k tokens/min per request); raise for more context.
AI_PROMPT_CANDLE_WINDOW=20

# Market Data
MARKET_DATA_PROVIDER=twelve_data
TWELVE_DATA_API_KEY=your_twelve_data_api_key_here

# Analysis schedule
ANALYSIS_INTERVAL_MINUTES=15
ANALYSIS_CANDLE_COUNT=200
# Primary (decision) timeframe a signal is framed on. Appended automatically to
# the scalp frame if it is not listed in either set below.
ANALYSIS_TIMEFRAME=1h
# Per-style timeframe frames. Each style is framed on (and the model is shown)
# its own set; the union of the two is what gets fetched per run, so a shared
# timeframe (e.g. 4h) costs nothing extra. Slow frames (4h/1d) are served from
# the candle cache between bars, so the per-minute cost is dominated by the fast
# frames. Comma-separated, no spaces.
SCALP_TIMEFRAMES=5m,15m,1h,4h
SWING_TIMEFRAMES=4h,1d

# Outcome tracking — cadence of the sweep that re-checks open signals against
# fresh candles to detect TP/SL/expiry. Tighter than the analysis interval so
# closes surface promptly; one fetch per active pair per cycle (lowest timeframe).
# OUTCOME_INTERVAL_MINUTES=5

# Active pairs (comma-separated, no spaces)
ACTIVE_PAIRS=XAUUSD

# Signal lifetime per style (minutes). Scalp ages out in hours, swing in days.
# Drives the frontend freshness/expiry badge and the retention sweep.
# SIGNAL_SCALP_TTL_MINUTES=240
# SIGNAL_SWING_TTL_MINUTES=4320

# Signal quality gate — every run still emits a directional bias per style, but a
# bias is only marked actionable (should_trade) when the deterministic gate
# agrees. MIN_REWARD_RISK is the reward:risk-to-TP1 floor below which a setup is
# vetoed; QUALITY_TRADE_THRESHOLD is the blended-quality score (0..1) a surviving
# bias must clear to be actionable.
# MIN_REWARD_RISK=1.5
# QUALITY_TRADE_THRESHOLD=0.5

# Economic calendar (news awareness) — OFF by default; the pipeline then behaves
# exactly as if no events existed. When enabled, a high-impact event for the
# instrument within NEWS_BLACKOUT_MINUTES of now vetoes new trades (and the prompt
# widens caution). ECONOMIC_CALENDAR_EVENTS_JSON seeds the static provider — a
# JSON array of {title, currency, impact, scheduled_at(ISO-8601)}.
# ECONOMIC_CALENDAR_ENABLED=false
# NEWS_BLACKOUT_MINUTES=60
# ECONOMIC_CALENDAR_EVENTS_JSON=[{"title":"CPI","currency":"USD","impact":"high","scheduled_at":"2026-06-10T12:30:00+00:00"}]

# Real-time streaming (SSE) — GET /api/v1/stream pushes signal/run events to
# connected browsers. A keep-alive comment is sent every STREAM_HEARTBEAT_SECONDS
# so idle proxies don't drop the connection. STREAM_MAX_QUEUE bounds each client's
# buffer (a client that can't keep up is disconnected and resumes via
# Last-Event-ID); STREAM_REPLAY_BUFFER is the ring of recent events kept for that
# resume. Sensible defaults work out of the box; tune for high traffic.
# STREAM_HEARTBEAT_SECONDS=15
# STREAM_MAX_QUEUE=100
# STREAM_REPLAY_BUFFER=200

# Notifications — OFF by default; the notifier is then a no-op and the whole path
# is inert. When enabled, a background dispatcher consumes the same events the
# stream serves and pushes the ones that pass the preferences below to the
# configured channel. Telegram is the only provider today: set both the bot token
# and the target chat id (the "chatbot id") — both are required when enabled.
# NOTIFICATIONS_ENABLED=false
# NOTIFICATION_PROVIDER=telegram
# TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
# TELEGRAM_CHAT_ID=your_telegram_chat_id_here
# NOTIFICATION_TIMEOUT_SECONDS=10
# Preferences — the pure filter applied before dispatch.
# NOTIFICATION_MIN_CONFIDENCE=0.7
# NOTIFICATION_SIGNAL_TYPES=scalp,swing
# NOTIFICATION_ONLY_ACTIONABLE=true
# NOTIFICATION_ON_SIGNAL_CREATED=true
# NOTIFICATION_ON_SIGNAL_CLOSED=true
